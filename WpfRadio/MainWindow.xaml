<Window x:Class="WpfRadio.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Radio" Height="120" Width="450"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="8">  <!--здесь мы создаем пространство в котором создаем строки в которых потом всё разместим, назначаем отступ-->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="UrlBox" Grid.Row="0" Margin="0,0,0,8"> <!--создаем место для текста, даем имя, назначаем место, отступ-->
            
        </TextBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <!--создаем место для кнопак, назначаем место,позицию и центруем-->
            <Button x:Name="PlayBtn" Content="Play" Width="70" Margin="4" Click="Play_Click"/> <!--создаем кнопки, даем имя, назначаем контекст и ее размеры, а также даем имя того что будет при нажатии-->
            <Button x:Name="StopBtn" Content="Stop" Width="70" Margin="4" IsEnabled="False" Click="Stop_Click"/>
        </StackPanel>
    </Grid>
</Window>